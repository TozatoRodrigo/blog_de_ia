{
  "name": "radar-ia-blog",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "node --disable-warning=ExperimentalWarning --experimental-strip-types --test tests/*.test.mjs",
    "test:leads": "npm --prefix services/download-leads test",
    "generate:og": "node scripts/generate-og-images.mjs",
    "audit:dist": "node scripts/audit-dist.mjs",
    "validate": "npm run check && npm run generate:og && npm run build && npm test && npm run test:leads && npm run audit:dist"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.3.0",
    "astro": "^5.6.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "cheerio": "^1.2.0",
    "sharp": "^0.35.3",
    "typescript": "^5.9.3"
  }
}
