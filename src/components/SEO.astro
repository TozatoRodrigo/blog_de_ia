---
import { SITE, SITE_LOCALE } from '../config';
import type { Lang } from '../i18n/lang';
import { absoluteUrl, buildAlternates } from '../utils/seo';
import { organizationSchema, personSchema, websiteSchema } from '../utils/schema';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  canonical?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  lang?: Lang;
  alternateUrl?: string;
}

const {
  title,
  description: suppliedDescription,
  image = '/og/default.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  author = SITE.author,
  tags = [],
  canonical,
  noindex = false,
  jsonLd,
  lang = 'pt-BR',
  alternateUrl = '',
} = Astro.props;

const localizedSite = SITE_LOCALE[lang];
const trimAtWord = (value: string, max: number) => value.length <= max
  ? value
  : `${value.slice(0, max - 1).replace(/\s+\S*$/, '')}…`;
const rawDescription = suppliedDescription || localizedSite.description;
const description = trimAtWord(
  rawDescription.length < 70 ? `${rawDescription} ${localizedSite.tagline}.` : rawDescription,
  160,
);
const titleWithBrand = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${localizedSite.tagline}`;
const shortTitle = titleWithBrand.length < 30
  ? `${titleWithBrand} | ${lang === 'pt-BR' ? 'IA e Produto' : 'AI & Product'}`
  : titleWithBrand;
const compactTitle = shortTitle.length > 60
  ? (title || `${localizedSite.tagline} — ${SITE.name}`)
  : shortTitle;
const pageTitle = trimAtWord(compactTitle, 60);
const canonicalURL = absoluteUrl(canonical || Astro.url.pathname);
const imageURL = new URL(image, Astro.site).toString();
const localeStr = lang === 'pt-BR' ? 'pt_BR' : 'en_US';
const structuredData = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

const allStructuredData = [websiteSchema(lang), organizationSchema(), personSchema(), ...structuredData];

const alternateUrls = alternateUrl
  ? buildAlternates(
      lang === 'pt-BR' ? Astro.url.pathname : alternateUrl,
      lang === 'en' ? Astro.url.pathname : alternateUrl,
    )
  : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<!-- Hreflang alternates -->
{alternateUrls && Object.entries(alternateUrls).map(([hreflang, href]) => (
  <link rel="alternate" hreflang={hreflang} href={href} />
))}

<meta name="theme-color" content="#f4f4f0" />
<meta name="color-scheme" content="light" />

<meta property="og:type" content={type} />
<meta property="og:title" content={title || SITE.name} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={localeStr} />
{alternateUrls && <meta property="og:locale:alternate" content={lang === 'pt-BR' ? 'en_US' : 'pt_BR'} />}
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{author && <meta property="article:author" content={author} />}
{tags.length > 0 && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title || SITE.name} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={title || SITE.name} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate" type="application/rss+xml" title={`${SITE.name} — RSS`} href="/rss.xml" />
<link rel="apple-touch-icon" href="/favicon.svg" />
<link rel="manifest" href="/site.webmanifest" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
  rel="stylesheet"
/>

{allStructuredData.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
