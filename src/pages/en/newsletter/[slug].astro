---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../config';
import { formatDate, formatDateISO } from '../../../utils/format';
import { topics } from '../../../data/topics';
import { t } from '../../../i18n/lang';
import { ui } from '../../../i18n/ui';

const lang = 'en' as const;

export async function getStaticPaths() {
  const newsletters = await getCollection('newsletters-en', ({ data }) => !data.draft);
  return newsletters.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allNewsletters = await getCollection('newsletters-en', ({ data }) => !data.draft);
allNewsletters.sort((a, b) => b.data.date.localeCompare(a.data.date));
const currentIndex = allNewsletters.findIndex((n) => n.id === entry.id);
const prev = currentIndex > 0 ? allNewsletters[currentIndex - 1] : null;
const next = currentIndex < allNewsletters.length - 1 ? allNewsletters[currentIndex + 1] : null;

const relatedTopics = topics.filter((topic) => entry.data.tags.some((tag) => topic.id === tag));
const topicHref = (tag: string) => {
  const topic = topics.find((candidate) => candidate.id === tag);
  return topic ? `/en/topics/${t(topic.slug, lang)}/` : '/en/topics/';
};

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: entry.data.title,
    description: entry.data.excerpt,
    datePublished: formatDateISO(entry.data.date),
    dateModified: formatDateISO(entry.data.date),
    author: {
      '@type': 'Person',
      name: SITE.author,
      jobTitle: SITE.authorRole,
      url: SITE.linkedin,
    },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      url: SITE.url,
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `${SITE.url}/en/newsletter/${entry.id}`,
    },
    keywords: entry.data.tags.join(', '),
    inLanguage: 'en',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/en/` },
      { '@type': 'ListItem', position: 2, name: 'Newsletter', item: `${SITE.url}/en/newsletter` },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: `${SITE.url}/en/newsletter/${entry.id}` },
    ],
  },
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  type="article"
  publishedTime={formatDateISO(entry.data.date)}
  tags={entry.data.tags}
  jsonLd={jsonLd}
  lang={lang}
  alternateUrl={`/newsletter/${entry.id}`}
>
  <article class="container" style="padding-top: 2rem;">
    <!-- Breadcrumb -->
    <nav class="mono-sm" style="display: flex; gap: 0.5rem; margin-bottom: 2rem; color: var(--fg-muted);">
      <a href="/en/" style="border: none; color: inherit;">HOME</a>
      <span>/</span>
      <a href="/en/newsletter" style="border: none; color: inherit;">NEWSLETTER</a>
      <span>/</span>
      <span style="color: var(--fg);">{formatDateISO(entry.data.date).replace(/[-:]/g, '').slice(0, 8)}</span>
    </nav>

    <!-- Article header -->
    <header class="article-header">
      <div class="article-header__eyebrow">
        <span class="accent">●</span>
        <span>{ui('article.edition', lang)} — {formatDate(entry.data.date, lang)}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <div class="article-header__meta">
        <span>{ui('article.by', lang)} — {SITE.author.toUpperCase()}</span>
        <span>{SITE.authorRole.toUpperCase()}</span>
        {entry.data.tags.map((tag) => (
          <a href={topicHref(tag)} class="tag" style="text-decoration: none; border-bottom: none;">#{tag}</a>
        ))}
      </div>
    </header>

    <!-- Article body -->
    <div class="article-body">
      <Content />
    </div>

    <!-- Tags -->
    <div style="max-width: 760px; margin: 3rem auto 0; padding-top: 2rem; border-top: 2px solid var(--line);">
      <span class="mono" style="color: var(--fg-muted);">[ {ui('article.tags', lang)} ]</span>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
        {entry.data.tags.map((tag) => (
          <a href={topicHref(tag)} class="tag" style="text-decoration: none;">#{tag}</a>
        ))}
      </div>
    </div>

    <!-- Related topics -->
    {relatedTopics.length > 0 && (
      <div style="max-width: 760px; margin: 3rem auto 0;">
        <div class="divider-label"><span>{ui('article.relatedTopics', lang)}</span></div>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          {relatedTopics.map((topic) => (
            <a href={`/en/topics/${t(topic.slug, lang)}/`} class="btn">{t(topic.name, lang)} →</a>
          ))}
        </div>
      </div>
    )}

    <!-- Author box -->
    <div class="author-box" style="max-width: 760px; margin: 3rem auto 0; border: 2px solid var(--line); padding: 1.5rem; display: flex; gap: 1.5rem; align-items: start;">
      <div class="author-box__avatar" style="width: 64px; height: 64px; background: var(--fg); color: var(--fg-invert); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 1.5rem; flex-shrink: 0;">
        RT
      </div>
      <div>
        <span class="mono-sm" style="color: var(--accent);">{ui('article.aboutAuthor', lang)}</span>
        <h3 style="font-size: 1.25rem; margin: 0.5rem 0; text-transform: none;">{SITE.author}</h3>
        <p style="font-size: 0.875rem; color: var(--fg-soft); margin: 0;">{SITE.authorRole}. {ui('article.authorBio', lang)}</p>
        <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="mono-sm" style="color: var(--accent); margin-top: 0.75rem; display: inline-block;">{ui('cta.linkedin', lang)} →</a>
      </div>
    </div>

    <!-- Navigation -->
    <div style="max-width: 760px; margin: 3rem auto 0;" class="pagination">
      {prev ? (
        <a href={`/en/newsletter/${prev.id}`} style="border: none;">← {ui('article.prev', lang)}</a>
      ) : (
        <span style="color: var(--fg-muted);">← {ui('article.prev', lang)}</span>
      )}
      {next ? (
        <a href={`/en/newsletter/${next.id}`} style="border: none;">{ui('article.next', lang)} →</a>
      ) : (
        <span style="color: var(--fg-muted);">{ui('article.next', lang)} →</span>
      )}
    </div>
  </article>
</BaseLayout>
