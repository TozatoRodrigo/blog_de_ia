---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { guideClusters } from '../../../data/guideClusters';

const guides = await getCollection('guides-en', ({ data }) => !data.draft);
const guideById = new Map(guides.map((guide) => [guide.id, guide]));
---
<BaseLayout title="AI Guides for Product Managers" description="Practical guides to AI agents, AI governance and product management for better product decisions." lang="en" alternateUrl="/guias/">
  <section class="container" style="padding-top:4rem;padding-bottom:4rem">
    <span class="mono" style="color:var(--accent)">[ LIBRARY ]</span>
    <h1>AI Guides for Product Managers</h1>
    <p style="max-width:68ch;color:var(--fg-soft)">Verified and connected references for understanding agents, governing risk and improving product decisions.</p>
    {guideClusters.map((cluster) => {
      const clusterGuides = cluster.items.map((item) => guideById.get(item.en)).filter(Boolean);
      return <section data-guide-cluster={cluster.id} style="margin-top:3.5rem">
        <span class="mono-sm">[ TOPICAL CLUSTER ]</span>
        <h2>{cluster.name.en}</h2>
        <p style="max-width:68ch;color:var(--fg-soft)">{cluster.description.en}</p>
        <div class="grid grid-2" style="margin-top:1.5rem">
          {clusterGuides.map((guide) => guide && <a class="topic-card" href={`/en/guides/${guide.id}/`}>
            <span class="topic-card__num">{guide.data.isHub ? 'PILLAR GUIDE' : `UPDATED ${guide.data.dateModified}`}</span>
            <span class="topic-card__title">{guide.data.title}</span>
            <span class="topic-card__desc">{guide.data.description}</span>
          </a>)}
        </div>
      </section>;
    })}
  </section>
</BaseLayout>
