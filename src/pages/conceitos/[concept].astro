---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { concepts } from '../../data/concepts';
import { topics } from '../../data/topics';
import { SITE } from '../../config';
import { t } from '../../i18n/lang';
import { ui } from '../../i18n/ui';

const lang = 'pt-BR' as const;

export async function getStaticPaths() {
  return concepts.map((concept) => ({ params: { concept: concept.slug['pt-BR'] }, props: { concept } }));
}

const { concept } = Astro.props;
const relatedTopics = topics.filter((tp) => concept.relatedTerms.includes(tp.id));
const relatedConcepts = concepts.filter((c) => c.id !== concept.id && c.relatedTerms.some((rt) => concept.relatedTerms.includes(rt)));
const alternateUrl = `/en/concepts/${concept.slug['en']}`;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'DefinedTerm', name: t(concept.term, lang), description: t(concept.definition, lang), url: `${SITE.url}/conceitos/${t(concept.slug, lang)}`, inLanguage: 'pt-BR', partOf: { '@type': 'DefinedTermSet', name: 'Glossário Produto com IA', url: `${SITE.url}/conceitos` } },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Início', item: SITE.url }, { '@type': 'ListItem', position: 2, name: 'Conceitos', item: `${SITE.url}/conceitos` }, { '@type': 'ListItem', position: 3, name: t(concept.term, lang), item: `${SITE.url}/conceitos/${t(concept.slug, lang)}` }] },
];
---

<BaseLayout title={`O que é ${t(concept.term, lang)}?`} description={t(concept.definition, lang)} tags={concept.relatedTerms} jsonLd={jsonLd} lang={lang} alternateUrl={alternateUrl}>
  <article class="container" style="padding-top: 2rem; max-width: 840px;">
    <nav class="mono-sm" style="display: flex; gap: 0.5rem; margin-bottom: 2rem; color: var(--fg-muted); flex-wrap: wrap;">
      <a href="/" style="border: none; color: inherit;">INÍCIO</a><span>/</span>
      <a href="/conceitos" style="border: none; color: inherit;">CONCEITOS</a><span>/</span>
      <span style="color: var(--fg);">{t(concept.term, lang).toUpperCase()}</span>
    </nav>
    <header class="article-header">
      <div class="article-header__eyebrow"><span class="accent">●</span><span>{ui('concept.category', lang)} — {t(concept.category, lang).toUpperCase()}</span></div>
      <h1>{ui('concept.whatIs', lang)} {t(concept.term, lang)}?</h1>
    </header>
    <div class="article-body">
      <p style="font-size: var(--step-2); color: var(--fg); font-weight: 600; line-height: 1.4;">{t(concept.definition, lang)}</p>
      <hr />
      <h2>{ui('concept.detailed', lang)}</h2>
      <p>{t(concept.longDescription, lang)}</p>
    </div>
    {relatedTopics.length > 0 && (
      <div style="margin-top: 3rem;"><div class="divider-label"><span>{ui('article.relatedTopics', lang)}</span></div><div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">{relatedTopics.map((tp) => <a href={`/topicos/${t(tp.slug, lang)}`} class="btn">{t(tp.name, lang)} →</a>)}</div></div>
    )}
    {relatedConcepts.length > 0 && (
      <div style="margin-top: 2rem;"><div class="divider-label"><span>{ui('concept.relatedTerms', lang)}</span></div><div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">{relatedConcepts.map((c) => <a href={`/conceitos/${t(c.slug, lang)}`} class="btn">{t(c.term, lang)} →</a>)}</div></div>
    )}
  </article>
</BaseLayout>
